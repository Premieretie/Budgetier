# =============================================================================
# Budgetier Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/budgetier

# =============================================================================
# JWT AUTHENTICATION
# Generate a strong secret: openssl rand -base64 32
# =============================================================================
JWT_SECRET=your_super_secret_jwt_key_here

# =============================================================================
# BASIQ / OPEN BANKING INTEGRATION
# Get your API key from: https://dashboard.basiq.io/
# =============================================================================
BASIQ_API_KEY=your_basiq_api_key_here
BASIQ_API_URL=https://au-api.basiq.io

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3000
NODE_ENV=development

# =============================================================================
# FRONTEND URL (for CORS and redirect URLs)
# =============================================================================
FRONTEND_URL=http://localhost:3000

# =============================================================================
# STRIPE (Optional - for premium subscriptions)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_price_id

# =============================================================================
# SYNC SCHEDULER (Optional)
# Cron expression for automatic transaction sync
# Default: Every 6 hours
# =============================================================================
SYNC_INTERVAL=0 */6 * * *
