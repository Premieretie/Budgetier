# API Configuration
# Development: Use your local backend port (3000)
# Production: Set this to your actual API domain
REACT_APP_API_URL=https://api.budgetier.ink

# App Configuration
REACT_APP_NAME=Budgetier
REACT_APP_VERSION=1.0.0

# Feature Flags
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_NOTIFICATIONS=true

# =============================================================================
# IMPORTANT: Never commit .env file with real values to version control
# =============================================================================
# For production deployment:
# 1. Copy this file to .env
# 2. Update REACT_APP_API_URL to your production API (e.g., https://api.budgetier.ink)
# 3. Ensure .env is listed in .gitignore (already configured)
#
# Hosting Platform Instructions:
# - Render: Set REACT_APP_API_URL in Environment Variables section
# - Netlify: Add to Site Settings > Environment Variables
# - Vercel: Add to Project Settings > Environment Variables
# =============================================================================
